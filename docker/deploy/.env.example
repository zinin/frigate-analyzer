# Database (external PostgreSQL)
DB_HOST=192.168.1.100
DB_PORT=5432
DB_NAME=frigate_analyzer
DB_USER=frigate_analyzer_rw
DB_PASS=secret

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_OWNER=your-username

# Paths
FRIGATE_RECORDS_FOLDER=/mnt/data/frigate/recordings

# Host port mapping (internal container port is always 8080)
HOST_PORT=8080

# Logging
LOG_LEVEL=info
APP_LOG_LEVEL=info

# Docker image version (use specific version for reproducible deploys)
IMAGE_TAG=latest

# --- AI descriptions (optional) ---
# Enables Claude-generated short + detailed descriptions of detection frames.
# Comments are placed above each variable (not inline) so the line is safe to uncomment —
# env_file parsers (docker compose, systemd EnvironmentFile) do NOT treat `#` as an inline
# comment and would otherwise bake the text into the value.
# APP_AI_DESCRIPTION_ENABLED=true
# APP_AI_DESCRIPTION_PROVIDER=claude
# Language for AI descriptions: ru | en (validated at startup via @Pattern).
# APP_AI_DESCRIPTION_LANGUAGE=en
# APP_AI_DESCRIPTION_SHORT_MAX=200
# APP_AI_DESCRIPTION_DETAILED_MAX=1500
# Top-N frames by detection quality (max confidence, then detection count) — same ranking
# as the user-visible media group, so Claude describes exactly what the user receives.
# APP_AI_DESCRIPTION_MAX_FRAMES=10
# Waiting-for-semaphore-permit budget (before describe() starts).
# APP_AI_DESCRIPTION_QUEUE_TIMEOUT=30s
# Total budget for describe + retry (after the semaphore permit is acquired).
# APP_AI_DESCRIPTION_TIMEOUT=60s
# APP_AI_DESCRIPTION_MAX_CONCURRENT=2

# --- Claude-specific (when provider=claude) ---
# Obtain the token ONCE on the host: `claude setup-token`,
# copy the value here. Long-lived OAuth token (works against your Claude subscription).
# CLAUDE_CODE_OAUTH_TOKEN=
# Model alias: opus | sonnet | haiku (resolved to current version by the CLI).
# CLAUDE_MODEL=opus
# Empty = SDK resolves via `which claude`. Non-empty = explicit binary path.
# CLAUDE_CLI_PATH=
# Empty = uses application.temp-folder (required for SDK).
# CLAUDE_WORKING_DIR=

# --- Optional Anthropic-compatible provider overrides ---
# When set, CLAUDE_CODE_OAUTH_TOKEN is not required.
# Allows routing Claude CLI requests through alternative providers
# (e.g., Alibaba DashScope, local proxy, etc.).
# At least one of CLAUDE_CODE_OAUTH_TOKEN or ANTHROPIC_AUTH_TOKEN is required.
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://example.com/apps/anthropic
# ANTHROPIC_MODEL=<model-name>
# ANTHROPIC_DEFAULT_OPUS_MODEL=<model-name>
# ANTHROPIC_DEFAULT_SONNET_MODEL=<model-name>
# ANTHROPIC_DEFAULT_HAIKU_MODEL=<model-name>

# --- Optional proxy for Claude API calls ---
# CLAUDE_HTTP_PROXY=http://proxy:8080
# CLAUDE_HTTPS_PROXY=http://proxy:8080
# CLAUDE_NO_PROXY=localhost,127.0.0.1

# --- Notification tracker (object tracking + suppression) ---
NOTIFICATIONS_TRACK_TTL=PT2M
NOTIFICATIONS_TRACK_IOU_THRESHOLD=0.3
NOTIFICATIONS_TRACK_INNER_IOU=0.5
NOTIFICATIONS_TRACK_CONFIDENCE_FLOOR=0.3
NOTIFICATIONS_TRACK_CLEANUP_INTERVAL_MS=3600000
NOTIFICATIONS_TRACK_CLEANUP_RETENTION=PT1H
